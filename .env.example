# CodeCanvas — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# App Environment (local | production)
APP_ENV=local

# Database Configuration
DB_HOST=localhost
DB_NAME=codecanvas
DB_USER=root
DB_PASS=

# Google OAuth
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost/CodeCanvas/auth/google-callback.php"

# AI Model API Keys
GOOGLE_AI_KEY="YOUR_GOOGLE_AI_KEY"
GROQ_API_KEY="YOUR_GROQ_API_KEY"
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"

# Resend Email API
RESEND_API_KEY="re_your_api_key_here"
MAIL_FROM="CodeCanvas <noreply@yourdomain.com>"

# Deployment via Vercel API v13
# Required to natively deploy SaaS static sites
VERCEL_TOKEN="YOUR_VERCEL_TOKEN"
VERCEL_TEAM_ID="" # Optional
