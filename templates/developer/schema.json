{
  "template": "developer",
  "name": "Developer Portfolio",
  "description": "A hacker-aesthetic dark portfolio template for developers.",
  "fields": [
    {
      "id": "full_name",
      "label": "Full Name",
      "type": "text",
      "selector": ".hacker-name",
      "attribute": "innerText",
      "placeholder": "HARSH\nRATHORE",
      "defaultValue": "HARSH\nRATHORE",
      "section": "Hero",
      "hint": "Your name will appear large in the hero section. Use uppercase."
    },
    {
      "id": "nav_logo",
      "label": "Nav Logo / Initials",
      "type": "text",
      "selector": "#nav-logo-link",
      "attribute": "innerText",
      "placeholder": "HR_",
      "defaultValue": "HR_",
      "section": "Navigation",
      "hint": "Short initials shown in the top navigation bar."
    },
    {
      "id": "title",
      "label": "Job Title / Role",
      "type": "text",
      "selector": "#hero-job-title",
      "attribute": "innerText",
      "placeholder": "Web Developer",
      "defaultValue": "Web Developer",
      "section": "Hero",
      "hint": "Your professional title shown below your name."
    },
    {
      "id": "about",
      "label": "About Me",
      "type": "textarea",
      "selector": "#about-bio-text",
      "attribute": "innerText",
      "placeholder": "I am a dedicated Web Developer with a passion for building clean, efficient, and scalable digital solutions...",
      "defaultValue": "I am Harsh Rathore, a dedicated Web Developer with a passion for building clean, efficient, and scalable digital solutions. My approach blends technical precision with minimalist aesthetics. I don't just write code; I architect experiences that perform seamlessly across all devices.",
      "section": "About",
      "hint": "Your bio paragraph in the About section."
    },
    {
      "id": "profile_image",
      "label": "Profile / Avatar Image",
      "type": "image",
      "selector": "#about-profile-img",
      "attribute": "src",
      "placeholder": "man.png",
      "defaultValue": "man.png",
      "section": "About",
      "hint": "Upload your profile photo or avatar. Recommended: square image."
    },
    {
      "id": "resume_url",
      "label": "Resume / CV",
      "type": "file",
      "selector": "#resume-download-link",
      "attribute": "href",
      "placeholder": "Upload your resume (PDF)",
      "defaultValue": "#",
      "section": "About",
      "hint": "Upload your resume PDF. Visitors will be able to download it directly from your portfolio."
    },
    {
      "id": "years_exp",
      "label": "Years of Experience",
      "type": "text",
      "selector": "#about-years-exp",
      "attribute": "innerText",
      "placeholder": "3+",
      "defaultValue": "3+",
      "section": "About",
      "hint": "Stat shown in the About section."
    },
    {
      "id": "projects_count",
      "label": "Projects Count",
      "type": "text",
      "selector": "#about-projects-count",
      "attribute": "innerText",
      "placeholder": "50+",
      "defaultValue": "50+",
      "section": "About",
      "hint": "Number of projects stat shown in the About section."
    },
    {
      "id": "skills",
      "label": "Skills / Tech Stack",
      "type": "array",
      "selector": "#skills .grid",
      "itemSelector": ".group.bg-black\\/40",
      "itemLabelSelector": "span.font-hacker",
      "itemIconSelector": "span.material-icons",
      "attribute": "innerText",
      "placeholder": [
        "PHP",
        "JavaScript",
        "Node.js",
        "Java",
        "MySQL",
        "HTML/CSS",
        "React",
        "AWS",
        "Git",
        "Figma"
      ],
      "defaultValue": [
        {
          "name": "PHP",
          "icon": "code"
        },
        {
          "name": "JavaScript",
          "icon": "javascript"
        },
        {
          "name": "Node.js",
          "icon": "data_object"
        },
        {
          "name": "Java",
          "icon": "coffee"
        },
        {
          "name": "MySQL",
          "icon": "storage"
        },
        {
          "name": "HTML/CSS",
          "icon": "html"
        },
        {
          "name": "React",
          "icon": "view_quilt"
        },
        {
          "name": "AWS",
          "icon": "cloud_queue"
        },
        {
          "name": "Git",
          "icon": "terminal"
        },
        {
          "name": "Figma",
          "icon": "design_services"
        }
      ],
      "section": "Skills",
      "hint": "Add or remove skills. Each skill shows an icon and name."
    },
    {
      "id": "projects",
      "label": "Featured Projects",
      "type": "group",
      "selector": "#projects .grid.grid-cols-1",
      "itemSelector": ".group.relative.rounded-lg",
      "attribute": "group",
      "defaultValue": [
        {
