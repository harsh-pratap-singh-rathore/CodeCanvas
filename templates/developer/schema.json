          "category": "FINTECH • 2023",
          "description": "Financial analytics platform built with React and Node.js.",
          "tags": [
            "React",
            "Node",
            "D3.js"
          ],
          "link": "#",
          "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuCkvMgPNUfQE8xwnMaDCXsmbHSthnXPIH_BfOyEqJYrJcN7iUvb73mpKkpPGt75Kmr7YPbYhsatBQzB_3dhUM6Xj1tCQGTHVpydhMW6eKCbAyQaNVLHQalsLBwqDoJae7sMFSlFH3AsbOppb8KsJU-QydTl1guqYzXMnLSTInnaxrPuYeteBS6l84ENgpE4UwAUbgjKJpGmGzvtPvzm568Z7paQupp37z5cIotEV4XHgTIZ3bbydr1WUVtOm1N06bUV6941ICxI-"
        },
        {
          "title": "Noir Boutique",
          "category": "E-COMMERCE • 2022",
          "description": "Premium fashion platform with custom PHP backend.",
          "tags": [
            "PHP",
            "MySQL",
            "Stripe"
          ],
          "link": "#",
          "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuBkCQUNb2HnWpW6S82h66JhrUKlUj7FBwxr0cNj5ZYTZFn0JFjEEnTGQDPEN8GztHF8l82z6qKSCHYvQx2y742bmiDmx2KrrPYnehZrux6DzCrkkWtDT1IhKqcsBq7AI9ZgFYZ13YBitOg51XQX3b6-_wa0a147wyICJRs4EKaUsbutIXVzUxNfS4Y_RH859U_ZRybU_U3o-wgo-Ri40lo9ZCDyqrlrWElMbH8-cNF-mzxhuTv6SqiArqdKIZXnRO-0ebp42tcTZnf4"
        },
        {
          "title": "Vortex API",
          "category": "SAAS • 2023",
          "description": "Secure API management tool for developers.",
          "tags": [
            "Java",
            "Spring",
            "Docker"
          ],
          "link": "#",
          "image": "https://lh3.googleusercontent.com/aida-public/AB6AXuD2M_KNjRkwGuOUS-9jBfJN-89oPxT3H9l6Ajyrk1p21HElmngGAUoL3dVsQU7BAcY9fVWxJEDJWB1ImCWKhaEffLbExMgDO2UjcoMxflTane-P_ekvB906E-xVGOF2RoM9Ac9pZqXWR8XLBdlUuGIlteMtzY_qsBZQvFTFktj5LnDiYK3ad8G5P4WYridE27_XxOAQdP3uMjCH-QhiYNmYNH--EKRQaE5T462ptc-3Ekw-Rm2u--tQguA_Y_HeO2naJqOCHRl8cRVZ"
        }
      ],
      "section": "Projects",
      "hint": "Add, edit, or remove featured projects."
    },
    {
      "id": "email",
      "label": "Email Address",
      "type": "email",
      "selector": "#contact-email-link",
      "attribute": "innerText",
      "hrefSelector": "#contact-email-link",
      "hrefAttribute": "href",
      "hrefPrefix": "mailto:",
      "placeholder": "harsh@example.com",
      "defaultValue": "harsh@example.com",
      "section": "Contact",
      "hint": "Your contact email shown in the Contact section."
    },
    {
      "id": "location",
      "label": "Location",
      "type": "text",
      "selector": "#contact-location-text",
      "attribute": "innerText",
      "placeholder": "India",
      "defaultValue": "India",
      "section": "Contact",
      "hint": "Your city or country shown in the Contact section."
    },
    {
      "id": "footer_name",
      "label": "Footer Name",
      "type": "text",
      "selector": "#footer-copyright-text",
      "attribute": "innerText",
      "placeholder": "© 2023 Harsh Rathore. All rights reserved.",
      "defaultValue": "© 2023 Harsh Rathore. All rights reserved.",
      "section": "Footer",
      "hint": "Copyright text in the footer."
    },
    {
      "id": "typing_words",
      "label": "Typing Animation Words",
      "type": "array",
      "selector": "#typing-text",
      "attribute": "data-words",
      "isScript": true,
      "scriptVar": "words",
      "placeholder": [
        "PHP",
        "Node.js",
        "Java",
        "React",
        "MySQL"
      ],
      "defaultValue": [
        "PHP",
        "Node.js",
        "Java",
        "React",
        "MySQL"
      ],
      "section": "Hero",
      "hint": "Words that cycle in the typing animation below your name."
    }
  ]
}