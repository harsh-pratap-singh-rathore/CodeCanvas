{
    "template": "shop",
    "name": "Shop Landing Page",
    "description": "A premium dark e-commerce landing page with hero product showcase, product grid, features, and CTA banner.",
    "fields": [
        {
            "id": "nav_logo",
            "label": "Store Name (Nav Logo)",
            "type": "text",
            "selector": "#nav_logo",
            "attribute": "innerText",
            "placeholder": "SHOP.",
            "defaultValue": "SHOP.",
            "section": "Navigation",
            "hint": "Your store name shown in the navigation bar."
        },
        {
            "id": "nav_cta_text",
            "label": "Nav CTA Button Text",
            "type": "text",
            "selector": "#nav_cta_text",
            "attribute": "innerText",
            "placeholder": "Shop Now",
            "defaultValue": "Shop Now",
            "section": "Navigation",
            "hint": "Text on the button in the top navigation."
        },
        {
            "id": "hero_badge",
            "label": "Hero Badge Text",
            "type": "text",
            "selector": "#hero_badge",
            "attribute": "innerText",
            "placeholder": "✦  New Collection 2026",
            "defaultValue": "✦  New Collection 2026",
            "section": "Hero",
            "hint": "Small badge tag shown above the headline."
        },
        {
            "id": "hero_headline",
            "label": "Hero Headline",
            "type": "text",
            "selector": "#hero_headline",
            "attribute": "innerText",
            "placeholder": "Premium Products for Modern Lives.",
            "defaultValue": "Premium Products for Modern Lives.",
            "section": "Hero",
            "hint": "Main large headline in the hero section."
        },
        {
            "id": "hero_sub",
            "label": "Hero Subtitle",
            "type": "textarea",
            "selector": "#hero_sub",
            "attribute": "innerText",
            "placeholder": "Handpicked, designed with care, and built to last.",
            "defaultValue": "Handpicked, designed with care, and built to last. We believe in quality over quantity — every single item.",
            "section": "Hero",
            "hint": "Paragraph below the hero headline."
        },
        {
            "id": "hero_trust_text",
            "label": "Trust Badge Text",
            "type": "text",
            "selector": "#hero_trust_text",
            "attribute": "innerText",
            "placeholder": "Trusted by 4,000+ happy customers",
            "defaultValue": "Trusted by 4,000+ happy customers",
            "section": "Hero",
            "hint": "Social proof text shown below the hero buttons."
        },
        {
            "id": "hero_product_name",
            "label": "Featured Product Name",
            "type": "text",
            "selector": "#hero_product_name",
            "attribute": "innerText",
            "placeholder": "Pro Wireless Headphones",
            "defaultValue": "Pro Wireless Headphones",
            "section": "Hero",
            "hint": "Name of the featured product card shown in the hero."
        },
        {
            "id": "hero_product_price",
            "label": "Featured Product Price",
            "type": "text",
            "selector": "#hero_product_price",
            "attribute": "innerText",
            "placeholder": "$249",
            "defaultValue": "$249",
            "section": "Hero",
            "hint": "Current price of the featured product."
        },
        {
            "id": "hero_product_old_price",
            "label": "Featured Product Old Price",
            "type": "text",
            "selector": "#hero_product_old_price",
            "attribute": "innerText",
            "placeholder": "$349",
            "defaultValue": "$349",
            "section": "Hero",
            "hint": "Original/crossed-out price of the featured product."
        },
        {
            "id": "products_heading",
            "label": "Products Section Heading",
            "type": "text",
            "selector": "#products_heading",
            "attribute": "innerText",
            "placeholder": "Featured Collection",
            "defaultValue": "Featured Collection",
            "section": "Products",
            "hint": "Heading above the product grid."
        },
        {
            "id": "p1_category",
            "label": "Product 1 — Category",
            "type": "text",
            "selector": "#p1_category",
            "attribute": "innerText",
            "placeholder": "Audio",
            "defaultValue": "Audio",
            "section": "Products",
            "hint": "Category label for the first product."
        },
        {
            "id": "p1_name",
            "label": "Product 1 — Name",
            "type": "text",
            "selector": "#p1_name",
            "attribute": "innerText",
            "placeholder": "Pro Wireless Headphones",
            "defaultValue": "Pro Wireless Headphones",
            "section": "Products",
            "hint": "Name of the first product."
        },
        {
            "id": "p1_desc",
            "label": "Product 1 — Description",
            "type": "textarea",
            "selector": "#p1_desc",
            "attribute": "innerText",
            "placeholder": "Studio-grade sound with 40-hour battery...",
            "defaultValue": "Studio-grade sound with 40-hour battery and active noise cancellation.",
            "section": "Products",
            "hint": "Short description for the first product."
        },
        {
            "id": "p1_price",
            "label": "Product 1 — Price",
            "type": "text",
            "selector": "#p1_price",
            "attribute": "innerText",
            "placeholder": "$249",
            "defaultValue": "$249",
            "section": "Products",
            "hint": "Price for the first product."
        },
        {
            "id": "p2_category",
            "label": "Product 2 — Category",
            "type": "text",
            "selector": "#p2_category",
            "attribute": "innerText",
            "placeholder": "Peripherals",
            "defaultValue": "Peripherals",
            "section": "Products",
            "hint": "Category label for the second product."
        },
        {
            "id": "p2_name",
            "label": "Product 2 — Name",
            "type": "text",
            "selector": "#p2_name",
            "attribute": "innerText",
            "placeholder": "Mechanical Keyboard",
            "defaultValue": "Mechanical Keyboard",
            "section": "Products",
            "hint": "Name of the second product."
        },
        {
            "id": "p2_desc",
            "label": "Product 2 — Description",
            "type": "textarea",
            "selector": "#p2_desc",
            "attribute": "innerText",
            "placeholder": "Tactile, silent switches...",
            "defaultValue": "Tactile, silent switches. Aluminium frame. Feels as good as it looks.",
            "section": "Products",
            "hint": "Short description for the second product."
        },
        {
            "id": "p2_price",
            "label": "Product 2 — Price",
            "type": "text",
            "selector": "#p2_price",
            "attribute": "innerText",
            "placeholder": "$189",
            "defaultValue": "$189",
            "section": "Products",
            "hint": "Price for the second product."
        },
        {
            "id": "p3_category",
            "label": "Product 3 — Category",
            "type": "text",
            "selector": "#p3_category",
            "attribute": "innerText",
            "placeholder": "Display",
            "defaultValue": "Display",
            "section": "Products",
            "hint": "Category label for the third product."
        },
        {
            "id": "p3_name",
            "label": "Product 3 — Name",
            "type": "text",
            "selector": "#p3_name",
            "attribute": "innerText",
            "placeholder": "4K Monitor Stand",
            "defaultValue": "4K Monitor Stand",
            "section": "Products",
            "hint": "Name of the third product."
        },
        {
            "id": "p3_desc",
            "label": "Product 3 — Description",
            "type": "textarea",
            "selector": "#p3_desc",
            "attribute": "innerText",
            "placeholder": "Elevate your setup...",
            "defaultValue": "Elevate your setup. Full articulation arm with cable management.",
            "section": "Products",
            "hint": "Short description for the third product."
        },
        {
            "id": "p3_price",
            "label": "Product 3 — Price",
            "type": "text",
            "selector": "#p3_price",
            "attribute": "innerText",
            "placeholder": "$129",
            "defaultValue": "$129",
            "section": "Products",
            "hint": "Price for the third product."
        },
        {
            "id": "features_heading",
            "label": "Features Section Heading",
            "type": "text",
            "selector": "#features_heading",
            "attribute": "innerText",
            "placeholder": "Our Promise to You",
            "defaultValue": "Our Promise to You",
            "section": "Features",
            "hint": "Heading above the features/why-us section."
        },
        {
            "id": "feat1_title",
            "label": "Feature 1 — Title",
            "type": "text",
            "selector": "#feat1_title",
            "attribute": "innerText",
            "placeholder": "Free Shipping",
            "defaultValue": "Free Shipping",
            "section": "Features",
            "hint": "Title of the first feature."
        },
        {
            "id": "feat1_desc",
            "label": "Feature 1 — Description",
            "type": "textarea",
            "selector": "#feat1_desc",
            "attribute": "innerText",
            "placeholder": "Free worldwide shipping on all orders over $50.",
            "defaultValue": "Free worldwide shipping on all orders over $50. Fast, reliable, tracked.",
            "section": "Features",
            "hint": "Description of the first feature."
        },
        {
            "id": "feat2_title",
            "label": "Feature 2 — Title",
            "type": "text",
            "selector": "#feat2_title",
            "attribute": "innerText",
            "placeholder": "Secure Checkout",
            "defaultValue": "Secure Checkout",
            "section": "Features",
            "hint": "Title of the second feature."
        },
        {
            "id": "feat2_desc",
            "label": "Feature 2 — Description",
            "type": "textarea",
            "selector": "#feat2_desc",
            "attribute": "innerText",
            "placeholder": "256-bit SSL encryption...",
            "defaultValue": "256-bit SSL encryption. Your payment details are always safe with us.",
            "section": "Features",
            "hint": "Description of the second feature."
        },
        {
            "id": "feat3_title",
            "label": "Feature 3 — Title",
            "type": "text",
            "selector": "#feat3_title",
            "attribute": "innerText",
            "placeholder": "Easy Returns",
            "defaultValue": "Easy Returns",
            "section": "Features",
            "hint": "Title of the third feature."
        },
        {
            "id": "feat3_desc",
            "label": "Feature 3 — Description",
            "type": "textarea",
            "selector": "#feat3_desc",
            "attribute": "innerText",
            "placeholder": "Not happy? Return within 30 days...",
            "defaultValue": "Not happy? Return within 30 days, no questions asked, full refund.",
            "section": "Features",
            "hint": "Description of the third feature."
        },
        {
            "id": "feat4_title",
            "label": "Feature 4 — Title",
            "type": "text",
            "selector": "#feat4_title",
            "attribute": "innerText",
            "placeholder": "24/7 Support",
            "defaultValue": "24/7 Support",
            "section": "Features",
            "hint": "Title of the fourth feature."
        },
        {
            "id": "feat4_desc",
            "label": "Feature 4 — Description",
            "type": "textarea",
            "selector": "#feat4_desc",
            "attribute": "innerText",
            "placeholder": "Our team is always on standby...",
            "defaultValue": "Our team is always on standby. Chat, email, or call — we're here for you.",
            "section": "Features",
            "hint": "Description of the fourth feature."
        },
        {
            "id": "cta_heading",
            "label": "CTA Heading",
            "type": "text",
            "selector": "#cta_heading",
            "attribute": "innerText",
            "placeholder": "Ready to upgrade your everyday?",
            "defaultValue": "Ready to upgrade your everyday?",
            "section": "CTA",
            "hint": "Main heading of the call-to-action banner."
        },
        {
            "id": "cta_body",
            "label": "CTA Description",
            "type": "textarea",
            "selector": "#cta_body",
            "attribute": "innerText",
            "placeholder": "Join thousands of customers who choose quality...",
            "defaultValue": "Join thousands of customers who choose quality. Limited stock available — don't miss out.",
            "section": "CTA",
            "hint": "Paragraph below the CTA heading."
        },
        {
            "id": "footer_copy",
            "label": "Footer Copyright",
            "type": "text",
            "selector": "#footer_copy",
            "attribute": "innerText",
            "placeholder": "© 2026 Shop. All rights reserved.",
            "defaultValue": "© 2026 Shop. All rights reserved.",
            "section": "Footer",
            "hint": "Copyright text in the footer."
        }
    ]
}